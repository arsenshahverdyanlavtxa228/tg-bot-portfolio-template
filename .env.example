# Get this from @BotFather on Telegram: /newbot
BOT_TOKEN=123456:your-bot-token-here

# Your Telegram user ID — get it from @userinfobot
# This account will have admin access to /admin commands.
ADMIN_ID=123456789

# SQLite path (inside container it maps to /app/data/bot.db via docker volume).
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Directory for uploaded files (CV, photos). Gets mounted as docker volume.
MEDIA_DIR=./media

# Default UI language: ru | en
DEFAULT_LOCALE=ru

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# (Optional) Drop pending updates on startup — useful after downtime.
DROP_PENDING_UPDATES=false
